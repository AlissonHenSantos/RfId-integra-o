generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Saca {
  id        Int         @id @default(autoincrement())
  tagId     String      @unique
  status    String      @default("RECEBIDA")
  peso      Float?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  logs      AccessLog[]
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  tagId     String
  saca      Saca?    @relation(fields: [tagId], references: [tagId])
  createdAt DateTime @default(now())
}
